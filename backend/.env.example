# Database Configuration
DATABASE_URL=postgresql://ai_analyst:secure_password_123@localhost:5432/ai_data_analyst

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Security
SECRET_KEY=your-secret-key-change-in-production-make-it-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
# IMPORTANT: File limits are environment-aware:
#   - ENVIRONMENT=development: No file size limit (10GB max allowed)
#   - ENVIRONMENT=production: 100MB maximum file size
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls

# Environment: development (no file limits) or production (100MB limit)
ENVIRONMENT=development
